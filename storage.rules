// Cloud Storage Security Rules for OCRS

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check user role from Firestore
    function getUserRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStudent() {
      return getUserRole() == 'student';
    }

    function isFaculty() {
      return getUserRole() == 'faculty';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    // Reports: Users can upload their own reports, admins can access all
    match /reports/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Student documents: Students can upload their own, faculty and admins can access
    match /student-documents/{userId}/{allPaths=**} {
      allow read: if request.auth.uid == userId || isFaculty() || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Faculty resources: Faculty and admins can manage
    match /faculty-resources/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Admin uploads: Only admins can manage
    match /admin-uploads/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
